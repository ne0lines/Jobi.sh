{
  "manifest_version": 3,
  "name": "Jobi.sh",
  "description": "Tar emot ett jobb från Jobi.sh och fyller i aktivitetsrapporten hos Arbetsförmedlingen.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/jobish-16.png",
    "32": "icons/jobish-32.png",
    "48": "icons/jobish-48.png",
    "128": "icons/jobish-128.png"
  },
  "permissions": ["contextMenus", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://jobi.sh/*",
    "https://*.jobi.sh/*",
    "https://arbetsformedlingen.se/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Jobi.sh",
    "default_icon": {
      "16": "icons/jobish-16.png",
      "32": "icons/jobish-32.png",
      "48": "icons/jobish-48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/jobish-16.png",
        "icons/jobish-32.png",
        "icons/jobish-48.png",
        "icons/jobish-128.png"
      ],
      "matches": [
        "https://arbetsformedlingen.se/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://jobi.sh/*",
        "https://*.jobi.sh/*"
      ],
      "js": ["content-jobish.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://arbetsformedlingen.se/platsbanken/annonser/*"
      ],
      "js": ["content-platsbanken.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://arbetsformedlingen.se/for-arbetssokande/mina-sidor/aktivitetsrapportera/lagg-till-aktivitet*"
      ],
      "js": ["content-af.js"],
      "run_at": "document_idle"
    }
  ]
}