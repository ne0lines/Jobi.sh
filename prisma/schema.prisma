generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Types ────────────────────────────────────────────────────

enum UserRole {
  user
  admin
}

enum JobStatus {
  saved
  applied
  in_process @map("in process")
  interview
  offer
  closed
}

// ─── Models ───────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String    @default("")
  role            UserRole  @default(user)
  profession      String    @default("")
  complete        Boolean   @default(false)
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  jobs  Job[]
  tasks Task[]
}

model Job {
  id             String    @id @default(cuid())
  userId         String
  title          String
  company        String
  location       String    @default("")
  employmentType String    @default("")
  workload       String    @default("")
  jobUrl         String    @default("")
  status         JobStatus @default(saved)
  notes          String    @default("")
  startDate      DateTime?
  closingDate    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactPerson ContactPerson?
  timeline      TimelineItem[]
  tasks         Task[]
}

model ContactPerson {
  id    String @id @default(cuid())
  jobId String @unique
  name  String @default("")
  role  String @default("")
  email String @default("")
  phone String @default("")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model TimelineItem {
  id    String @id @default(cuid())
  jobId String
  date  String // display string, e.g. "19 februari 2026"
  event String

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  jobId       String
  userId      String
  title       String
  description String    @default("")
  dueDate     DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
